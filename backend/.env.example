APP_ENV=development
API_TITLE="Real-Time Multifamily Property Analytics API"
API_VERSION="0.1.0"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

HUD_ARCGIS_URL="https://services.arcgis.com/VTyQ9soqVukalItT/arcgis/rest/services/Multifamily_Properties_Assisted/FeatureServer/0/query"
HUD_PAGE_SIZE=100
HUD_MAX_TEST_INGEST_RECORDS=500
HUD_REQUEST_TIMEOUT_SECONDS=30

FREDDIE_MAC_MLPD_DATA_DIR="../data/raw/freddie_mac_mlp"
FREDDIE_MAC_MLPD_BATCH_SIZE=500
FREDDIE_MAC_MLPD_MAX_TEST_INGEST_RECORDS=5000

SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL_PRIMARY=gemini-3.1-flash-lite
GEMINI_MODEL_FALLBACK=gemini-3.5-flash
